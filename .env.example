#--------------------------------------------------------------------------
# imanimen/laravel-sms-switch — example env
#
# Copy relevant lines into your consuming app's .env. Any provider you don't
# use can be left blank and disabled via <PROVIDER>_ENABLED=false.
#--------------------------------------------------------------------------

# Operating mode: `manual` = always use SMS_SWITCH_DEFAULT.
#                 `auto`   = score-based selection + circuit breaker.
SMS_SWITCH_MODE=manual
SMS_SWITCH_DEFAULT=smsir

#--- sms.ir ---------------------------------------------------------------
SMSIR_API_KEY=
SMSIR_LINE=30001111
SMSIR_BASE_URL=https://api.sms.ir
SMSIR_ENABLED=true

#--- Kavenegar ------------------------------------------------------------
KAVENEGAR_API_KEY=
KAVENEGAR_SENDER=10001
KAVENEGAR_BASE_URL=https://api.kavenegar.com
KAVENEGAR_ENABLED=true

#--- Melipayamak ----------------------------------------------------------
MELIPAYAMAK_USERNAME=
MELIPAYAMAK_PASSWORD=
MELIPAYAMAK_FROM=10001
MELIPAYAMAK_BASE_URL=https://rest.payamak-panel.com
MELIPAYAMAK_ENABLED=true

#--- MOBINSMS ------------------------------------------------------------
MOBINSMS_API_KEY=
MOBINSMS_BASE_URL=
MOBINSMS_FROM=
MOBINSMS_ENABLED=true

#--- Circuit breaker -----------------------------------------------------
SMS_CB_THRESHOLD=5
SMS_CB_OPEN_SECONDS=60
SMS_CB_HALFOPEN_SUCCESS=1

#--- Scoring (auto mode only) --------------------------------------------
SMS_SCORING_WINDOW_MIN=15
SMS_MAX_LATENCY_MS=3000

#--- Logging / retention -------------------------------------------------
SMS_LOGGING_ENABLED=true
SMS_LOG_RETENTION_DAYS=30
# SMS_LOG_CONNECTION=  # override DB connection for sms_logs / sms_provider_metrics

#--- HTTP client ---------------------------------------------------------
SMS_HTTP_TIMEOUT=5
SMS_HTTP_CONNECT_TIMEOUT=2

#--- Queue (Sms::queue / Sms::queuePattern) ------------------------------
# SMS_QUEUE_CONNECTION=redis
SMS_QUEUE_NAME=sms
